#!/usr/bin/env bash

# Detect PKGX_ROOT (works for system, user, or dev install)
if [ -d "$PKGX_ROOT" ]; then
    : # already set
elif [ -d "$HOME/.local/lib/pkgx" ]; then
    PKGX_ROOT="$HOME/.local/lib/pkgx"
elif [ -d "/usr/local/lib/pkgx" ]; then
    PKGX_ROOT="/usr/local/lib/pkgx"
else
    echo "Error: pkgx root not found!"
    exit 1
fi

# sanity check
if [ ! -d "$PKGX_ROOT" ]; then
    echo "Error: pkgx root not found!"
    exit 1
fi

# load libs
source "$PKGX_ROOT/lib/config.sh"
source "$PKGX_ROOT/lib/flags.sh"
source "$PKGX_ROOT/lib/util.sh"
source "$PKGX_ROOT/lib/backend.sh"
source "$PKGX_ROOT/lib/map.sh"

# enable logging / debug
enable_debug

# load commands
for cmd in "$PKGX_ROOT"/commands/*.sh; do
  source "$cmd"
done

# resolve command
CMD="$1"

if [ -z "$CMD" ] || [ -z "${CMD_MAP[$CMD]}" ]; then
  error "Unknown or missing command: ${CMD:-<none>}"
  exit 1
fi

shift

# debug AFTER shift (important)
debug "command: $CMD"
debug "args: $@"

FUNC="${CMD_MAP[$CMD]}"

if ! declare -f "$FUNC" >/dev/null; then
  error "Unknown command: $CMD"
  exit 1
fi

"$FUNC" "$@"