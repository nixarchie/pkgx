#!/usr/bin/env bash

# Try to auto-detect PKGX_ROOT based on where pkgx binary lives
if [ -n "$PKGX_ROOT" ]; then
    # user can override PKGX_ROOT explicitly
    :
elif [ -d "$HOME/.local/lib/pkgx" ]; then
    PKGX_ROOT="$HOME/.local/lib/pkgx"
else
    # fallback: resolve the binary via PATH
    PKGX_BIN_PATH="$(command -v pkgx 2>/dev/null || true)"
    if [ -n "$PKGX_BIN_PATH" ]; then
        # assuming standard layout: bin/pkgx → ../lib/pkgx
        PKGX_ROOT="$(dirname "$(dirname "$PKGX_BIN_PATH")")/lib/pkgx"
    else
        # ultimate fallback
        PKGX_ROOT="/usr/local/lib/pkgx"
    fi
fi

# sanity check
if [ ! -d "$PKGX_ROOT" ]; then
    echo "Error: pkgx root not found!"
    exit 1
fi

# load libs
source "$PKGX_ROOT/lib/config.sh"
source "$PKGX_ROOT/lib/flags.sh"
source "$PKGX_ROOT/lib/util.sh"
source "$PKGX_ROOT/lib/backend.sh"
source "$PKGX_ROOT/lib/map.sh"

# enable logging / debug
enable_debug

# load commands
for cmd in "$PKGX_ROOT"/commands/*.sh; do
  source "$cmd"
done

# resolve command
CMD="$1"

if [ -z "$CMD" ] || [ -z "${CMD_MAP[$CMD]}" ]; then
  error "Unknown or missing command: ${CMD:-<none>}"
  exit 1
fi

shift

# debug AFTER shift (important)
debug "command: $CMD"
debug "args: $@"

FUNC="${CMD_MAP[$CMD]}"

if ! declare -f "$FUNC" >/dev/null; then
  error "Unknown command: $CMD"
  exit 1
fi

"$FUNC" "$@"